<UserControl x:Class="ThermalDoctor.Views.ThrottlingChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" 
            BorderBrush="{DynamicResource ThemeBorderLightBrush}" BorderThickness="1" Padding="8,4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Thermal Throttling %" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeFgBrush}" Margin="4,0,0,2"/>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding ThrottleChartSeries}"
                                XAxes="{Binding ThrottleChartXAxes}"
                                YAxes="{Binding ThrottleChartYAxes}"
                                TooltipPosition="Top"
                                LegendPosition="Bottom"
                                LegendTextPaint="{Binding LegendTextPaint}"
                                ZoomMode="X"
                                AnimationsSpeed="00:00:00.150"/>
        </Grid>
    </Border>
</UserControl>
