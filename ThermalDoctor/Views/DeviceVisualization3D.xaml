<UserControl x:Class="ThermalDoctor.Views.DeviceVisualization3D"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="600"
             Background="Transparent">

    <Grid>
        <Border Background="{DynamicResource ThemeBgBrush}" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="{Binding DeviceModelName}" 
                           FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ThemeFgBrush}" Margin="16,12,16,4"
                           HorizontalAlignment="Center"/>

                <!-- 3D Viewport -->
                <Border Grid.Row="1" Margin="8" CornerRadius="8" ClipToBounds="True"
                        Background="{DynamicResource ThemeSurfaceBrush}">
                    <Grid>
                        <Viewport3D x:Name="MainViewport"
                                    ClipToBounds="True"
                                    MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                                    MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                                    MouseMove="Viewport_MouseMove"
                                    MouseWheel="Viewport_MouseWheel"
                                    MouseRightButtonDown="Viewport_MouseRightButtonDown"
                                    MouseRightButtonUp="Viewport_MouseRightButtonUp">

                            <Viewport3D.Camera>
                                <PerspectiveCamera x:Name="Camera"
                                                   Position="6,8,10"
                                                   LookDirection="-6,-8,-10"
                                                   UpDirection="0,1,0"
                                                   FieldOfView="45"
                                                   NearPlaneDistance="0.1"
                                                   FarPlaneDistance="100"/>
                            </Viewport3D.Camera>

                            <!-- Ambient light for base illumination -->
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <AmbientLight Color="#404060"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>

                            <!-- Key light from above-right -->
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Color="#C0C0E0" Direction="-1,-1.5,-0.8"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>

                            <!-- Fill light from left -->
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Color="#606080" Direction="1,-0.5,0.5"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>

                            <!-- Back light for rim -->
                            <ModelVisual3D>
                                <ModelVisual3D.Content>
                                    <DirectionalLight Color="#404060" Direction="0,0.5,1"/>
                                </ModelVisual3D.Content>
                            </ModelVisual3D>

                            <!-- Scene root — all geometry added here -->
                            <ModelVisual3D x:Name="SceneRoot"/>

                        </Viewport3D>

                        <!-- 2D overlay for labels (positioned via projection) -->
                        <Canvas x:Name="LabelOverlay" IsHitTestVisible="False"/>

                        <!-- Instructions overlay -->
                        <TextBlock Text="🖱 Drag to rotate · Scroll to zoom · Right-drag to pan"
                                   Foreground="{DynamicResource ThemeFgDimBrush}" FontSize="10"
                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                   Margin="0,0,0,6"/>
                    </Grid>
                </Border>

                <!-- Legend -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="8,2,8,10">
                    <TextBlock Text="Cool" Foreground="{DynamicResource ThemeFgDimBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Border Width="160" Height="10" CornerRadius="5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0064FF" Offset="0"/>
                                <GradientStop Color="#00C8FF" Offset="0.19"/>
                                <GradientStop Color="#00DC50" Offset="0.43"/>
                                <GradientStop Color="#FFE600" Offset="0.68"/>
                                <GradientStop Color="#FF8C00" Offset="0.87"/>
                                <GradientStop Color="#DC1414" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Hot" Foreground="#FF6644" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
