<UserControl x:Class="ThermalDoctor.Views.TemperatureTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500">

    <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="12" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Temperature Readings" 
                       FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource ThemeFgBrush}"
                       Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1" 
                      ItemsSource="{Binding Readings}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      Foreground="{DynamicResource ThemeFgBrush}"
                      BorderBrush="{DynamicResource ThemeBorderLightBrush}"
                      BorderThickness="1"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource ThemeBorderLightBrush}"
                      RowBackground="{DynamicResource ThemeBgBrush}"
                      AlternatingRowBackground="{DynamicResource ThemeSurfaceBrush}"
                      HeadersVisibility="Column"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowHeight="36"
                      ColumnHeaderHeight="38">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource ThemeControlBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource ThemeFgDimBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderLightBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" 
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeHighlightBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <!-- Component -->
                    <DataGridTextColumn Header="Component" Binding="{Binding ComponentName}" 
                                        Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Temperature -->
                    <DataGridTemplateColumn Header="Temp" Width="100" SortMemberPath="DisplayTemperature">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="10" Height="10" 
                                             Fill="{Binding HeatColor}" 
                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TemperatureDisplay}" 
                                               FontWeight="Bold" FontSize="14"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status -->
                    <DataGridTemplateColumn Header="Status" Width="90" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding StatusColor}" 
                                        CornerRadius="10" Padding="8,2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusDisplay}" 
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Trend -->
                    <DataGridTemplateColumn Header="Trend" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TrendSymbol}" 
                                           Foreground="{Binding TrendColor}"
                                           FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Throttling -->
                    <DataGridTemplateColumn Header="Throttle" Width="90" SortMemberPath="ThrottlePercentage">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding ThrottleBrush}" 
                                        CornerRadius="10" Padding="6,2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Opacity="0.85">
                                    <TextBlock Text="{Binding ThrottleDisplay}" 
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Thermal Limit -->
                    <DataGridTextColumn Header="Thrt Limit" Binding="{Binding ThermalLimitDisplay}" Width="72">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ThemeFgDimBrush}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- TjMax -->
                    <DataGridTextColumn Header="TjMax" Binding="{Binding TjMaxDisplay}" Width="62">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#E74C3C"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Zone ID -->
                    <DataGridTextColumn Header="Zone ID" Binding="{Binding ZoneId}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ThemeFgDimBrush}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Timestamp -->
                    <DataGridTextColumn Header="Updated" 
                                        Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" 
                                        Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource ThemeFgDimBrush}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
