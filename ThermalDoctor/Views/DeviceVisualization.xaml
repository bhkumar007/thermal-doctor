<UserControl x:Class="ThermalDoctor.Views.DeviceVisualization"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="500">

    <UserControl.Resources>
        <Style x:Key="ComponentTooltipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="#E0202020"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Background="#1A1A2E" CornerRadius="12" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0" Text="{Binding DeviceModelName}" 
                           FontSize="18" FontWeight="SemiBold" 
                           Foreground="#E0E0E0" Margin="0,0,0,12"
                           HorizontalAlignment="Center"/>

                <!-- Device Canvas -->
                <Viewbox Grid.Row="1" Stretch="Uniform" Margin="10">
                    <Canvas x:Name="DeviceCanvas" 
                            Width="{Binding DeviceWidth}" 
                            Height="{Binding DeviceHeight}"
                            ClipToBounds="False">

                        <!-- 3D device body - right edge -->
                        <Path Data="{Binding RightEdgePathData}" StrokeThickness="1">
                            <Path.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                                    <GradientStop Color="#252540" Offset="0"/>
                                    <GradientStop Color="#1a1a30" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Fill>
                            <Path.Stroke>
                                <SolidColorBrush Color="#3A3A5A"/>
                            </Path.Stroke>
                        </Path>

                        <!-- 3D device body - front edge -->
                        <Path Data="{Binding FrontEdgePathData}" StrokeThickness="1">
                            <Path.Fill>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#222240" Offset="0"/>
                                    <GradientStop Color="#161630" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Fill>
                            <Path.Stroke>
                                <SolidColorBrush Color="#3A3A5A"/>
                            </Path.Stroke>
                        </Path>

                        <!-- Device body top surface -->
                        <Path Data="{Binding DeviceOutlinePath}" Stroke="#4A4A6A" StrokeThickness="2">
                            <Path.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#323250" Offset="0"/>
                                    <GradientStop Color="#2D2D44" Offset="0.4"/>
                                    <GradientStop Color="#272740" Offset="1"/>
                                </LinearGradientBrush>
                            </Path.Fill>
                        </Path>

                        <!-- Screen area -->
                        <Path Data="{Binding DeviceScreenPath}" 
                              Fill="#0F0F1A" Stroke="#333355" StrokeThickness="1"/>

                        <!-- Component heat overlays -->
                        <ItemsControl ItemsSource="{Binding Readings}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" 
                                            Value="{Binding Position.X}"/>
                                    <Setter Property="Canvas.Top" 
                                            Value="{Binding Position.Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="{Binding Radius, Converter={StaticResource NegativeMarginConverter}}"
                                          ToolTipService.InitialShowDelay="200">
                                        <Grid.ToolTip>
                                            <ToolTip Style="{StaticResource ComponentTooltipStyle}">
                                                <StackPanel>
                                                    <TextBlock FontWeight="Bold" Text="{Binding ComponentName}"/>
                                                    <TextBlock Text="{Binding TemperatureDisplay}"/>
                                                    <TextBlock>
                                                        <Run Text="Status: "/><Run Text="{Binding StatusDisplay, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock>
                                                        <Run Text="Zone: "/><Run Text="{Binding ZoneId, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </ToolTip>
                                        </Grid.ToolTip>

                                        <!-- Outer glow -->
                                        <Ellipse Width="{Binding Radius, Converter={StaticResource DoubleMultiplierConverter}, ConverterParameter=2.4}"
                                                 Height="{Binding Radius, Converter={StaticResource DoubleMultiplierConverter}, ConverterParameter=2.4}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="{Binding HeatColorTranslucent.Color}" Offset="0.2"/>
                                                    <GradientStop Color="Transparent" Offset="1.0"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Main circle -->
                                        <Ellipse Width="{Binding Radius, Converter={StaticResource DoubleMultiplierConverter}, ConverterParameter=2}"
                                                 Height="{Binding Radius, Converter={StaticResource DoubleMultiplierConverter}, ConverterParameter=2}"
                                                 Fill="{Binding HeatColorTranslucent}"
                                                 Stroke="{Binding HeatColor}" StrokeThickness="2"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        <!-- Label -->
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Label}" 
                                                       FontSize="7" FontWeight="Bold"
                                                       Foreground="White" 
                                                       HorizontalAlignment="Center"
                                                       Effect="{StaticResource TextShadow}"/>
                                            <TextBlock Text="{Binding TemperatureDisplay}" 
                                                       FontSize="6" 
                                                       Foreground="White" 
                                                       HorizontalAlignment="Center"
                                                       Effect="{StaticResource TextShadow}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </Viewbox>

                <!-- Color legend -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <TextBlock Text="Cool" Foreground="#88AACC" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Border Width="200" Height="12" CornerRadius="6">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0064FF" Offset="0"/>
                                <GradientStop Color="#00C8FF" Offset="0.15"/>
                                <GradientStop Color="#00DC50" Offset="0.35"/>
                                <GradientStop Color="#FFE600" Offset="0.55"/>
                                <GradientStop Color="#FF8C00" Offset="0.75"/>
                                <GradientStop Color="#DC1414" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Hot" Foreground="#FF6644" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <TextBlock Text="  20°C" Foreground="#777" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text=" — " Foreground="#555" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="100°C" Foreground="#777" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
