<Window x:Class="ThermalDoctor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ThermalDoctor.Views"
        xmlns:helpers="clr-namespace:ThermalDoctor.Helpers"
        mc:Ignorable="d"
        Title="Surface Thermal Monitor" 
        Height="720" Width="1200" MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeBgBrush}"
        Icon="/Assets/app.png"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <helpers:HeatColorConverter x:Key="HeatColorConverter"/>
        <helpers:HeatColorWithOpacityConverter x:Key="HeatColorWithOpacityConverter"/>
        <helpers:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <helpers:TrendToSymbolConverter x:Key="TrendToSymbolConverter"/>
        <helpers:TrendToColorConverter x:Key="TrendToColorConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>



        <!-- Button style -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeControlBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeFgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeControlHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeControlPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="8"/>      <!-- Splitter -->
            <RowDefinition Height="350" MinHeight="160"/>  <!-- Charts -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeSurfaceBrush}" Padding="12,8" BorderBrush="{DynamicResource ThemeBorderLightBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌡" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Surface Thermal Monitor" FontSize="16" FontWeight="Bold" 
                                   Foreground="{DynamicResource ThemeFgBrush}"/>
                        <TextBlock Text="{Binding DeviceModelName}" FontSize="11" 
                                   Foreground="{DynamicResource ThemeFgDimBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Center: Summary stats -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" 
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="{DynamicResource ThemeControlBrush}" CornerRadius="8" Padding="12,4" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="MAX TEMP" FontSize="9" Foreground="{DynamicResource ThemeFgDimBrush}" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="#FF6644" 
                                       HorizontalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1}{1}">
                                        <Binding Path="MaxTemperatureDisplay"/>
                                        <Binding Path="TempUnit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource ThemeControlBrush}" CornerRadius="8" Padding="12,4" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="AVG TEMP" FontSize="9" Foreground="{DynamicResource ThemeFgDimBrush}" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="#44AAFF" 
                                       HorizontalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:F1}{1}">
                                        <Binding Path="AvgTemperatureDisplay"/>
                                        <Binding Path="TempUnit"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource ThemeControlBrush}" CornerRadius="8" Padding="12,4" Margin="6,0">
                        <StackPanel>
                            <TextBlock Text="LAST UPDATE" FontSize="9" Foreground="{DynamicResource ThemeFgDimBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding LastUpdated}" 
                                       FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ThemeFgDimBrush}" 
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right: Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Profile selector -->
                    <TextBlock Text="Profile:" Foreground="{DynamicResource ThemeFgDimBrush}" VerticalAlignment="Center" 
                               Margin="0,0,6,0" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding AvailableProfiles}" 
                              SelectedItem="{Binding SelectedProfileName}"
                              Width="130" Margin="0,0,10,0"
                              FontSize="11"/>

                    <!-- Polling interval -->
                    <TextBlock Text="Poll (s):" Foreground="{DynamicResource ThemeFgDimBrush}" VerticalAlignment="Center" 
                               Margin="0,0,4,0" FontSize="11"/>
                    <Slider Value="{Binding PollingIntervalSeconds}" 
                            Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                            Width="80" VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <Button Content="📋 Export CSV" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ExportCsvCommand}" Margin="0,0,6,0"/>
                    <Button Content="{Binding TempUnitButtonText}" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleTempUnitCommand}" Margin="0,0,6,0"
                            ToolTip="Toggle Celsius / Fahrenheit"/>
                    <Button Content="{Binding ThemeButtonText}" Style="{StaticResource ToolbarButton}"
                            Command="{Binding ToggleThemeCommand}" Margin="0,0,6,0"/>
                    <Button Content="🛡 Run as Admin" Style="{StaticResource ToolbarButton}"
                            Command="{Binding RunAsAdminCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content: Device viz + Table + Diagnostics -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" MinWidth="350"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Left: 3D Device visualization -->
            <local:DeviceVisualization3D Grid.Column="0" Grid.Row="0" 
                                         DataContext="{Binding}" Margin="4"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                          Width="4" Background="{DynamicResource ThemeBorderLightBrush}" 
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

            <!-- Right: Temperature table -->
            <local:TemperatureTable Grid.Column="2" Grid.Row="0" 
                                    DataContext="{Binding}" Margin="4"/>

            <!-- Bottom diagnostics log (spans both columns) -->
            <Expander Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3"
                      Header="Diagnostic Log" IsExpanded="False"
                      Foreground="{DynamicResource ThemeFgDimBrush}" Margin="4,4,4,0">
                <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="6" Padding="8" MaxHeight="150">
                    <ListBox ItemsSource="{Binding DiagnosticLog}" 
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource ThemeFgDimBrush}" FontSize="11" FontFamily="Consolas"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                </Border>
            </Expander>
        </Grid>

        <!-- Horizontal splitter between content and chart -->
        <GridSplitter Grid.Row="2" Height="4" 
                      Background="{DynamicResource ThemeBorderLightBrush}"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      ResizeDirection="Rows"/>

        <!-- Charts: Temperature + Throttling side by side -->
        <Grid Grid.Row="3" Margin="8,0,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <local:TemperatureChart Grid.Column="0" DataContext="{Binding}" Margin="0,0,4,0"/>
            <local:ThrottlingChart Grid.Column="1" DataContext="{Binding}" Margin="4,0,0,0"/>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="{DynamicResource ThemeSurfaceBrush}" Padding="12,4" 
                BorderBrush="{DynamicResource ThemeBorderLightBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                           Foreground="{DynamicResource ThemeFgDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" 
                           Text="{Binding IsAdmin, StringFormat='Admin: {0}'}" 
                           Foreground="{DynamicResource ThemeFgDimBrush}" FontSize="11" 
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
                <TextBlock Grid.Column="2" Text="v1.0" 
                           Foreground="{DynamicResource ThemeFgDimBrush}" FontSize="11" 
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
